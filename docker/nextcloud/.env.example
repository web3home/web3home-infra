# Copy to .env and fill real values. .env is gitignored.
# MYSQL_PASSWORD must match the dbpassword in the migrated config.php.
# Use alphanumeric-only passwords — $ and other shell-special chars break
# Docker Compose variable interpolation (learned the hard way).
MYSQL_ROOT_PASSWORD=use_openssl_rand_hex_24
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeme_must_match_config_php
NC_BIND_IP=192.168.1.10
