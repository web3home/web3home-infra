# Copy to .env and populate with real Migadu SMTP credentials.
# .env is gitignored — never commit real values.
# For multi-node deployment, use sops-encrypted secrets.sops.yaml instead.

GHOST_SMTP_USER=user@example.com
GHOST_SMTP_PASS=changeme
# LAN IP that bee001's Ghost binds to (for Traefik-on-Odroid to reach during migration).
# Defaults to 127.0.0.1 if unset. Set to bee001's LAN IP during the migration phase.
GHOST_BIND_IP=192.168.1.10
